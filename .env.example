# NusaTerminal - Environment Variables
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# ── LLM API Key ──────────────────────────────────────────────────────────────
# DeepSeek API (daftar di https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── Server Config ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── RAG Config ────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
NEWS_REFRESH_INTERVAL_MINUTES=15

# ── Cache Config ──────────────────────────────────────────────────────────────
MARKET_CACHE_TTL_SECONDS=60
NEWS_CACHE_TTL_SECONDS=300
